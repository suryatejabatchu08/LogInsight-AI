{
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "uvicorn api.main:app --reload --host 0.0.0.0 --port 3000",
  "installCommand": "pip install -r requirements.txt",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/api/main.py"
    }
  ]
}
